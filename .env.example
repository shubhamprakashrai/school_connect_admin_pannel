# Copy this file to .env.development (local) or .env.production (prod build).
# Vite loads .env.development for `vite dev` and .env.production for `vite build`.

# Backend API base URL. Spring Boot has context-path=/api, so include it.
VITE_API_BASE_URL=http://localhost:8080/api

# Default tenant identifier sent as X-Tenant-ID header until login response provides one.
VITE_DEFAULT_TENANT_ID=default

# Request timeout in milliseconds.
VITE_API_TIMEOUT=15000

# Enable verbose request/response logging in dev.
VITE_API_DEBUG=true
